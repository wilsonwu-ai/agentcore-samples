# Receipts IDP Agent — Local Development Environment
#
# Copy to .env and fill from your deployed stack outputs:
#   aws cloudformation describe-stacks --stack-name AgentCore-ReceiptsAgent-dev \
#     --query 'Stacks[0].Outputs' --region us-west-2 --output table
#
# Then run: agentcore dev --no-browser

# Model (optional — defaults to the L0 rung). In a deployed stack the degradation
# ladder resolves this from AppConfig; this is the local default + the fallback if
# AppConfig is unreachable.
# AGENT_MODEL_ID=global.anthropic.claude-opus-4-8

# MCP Gateway connection (from CloudFormation outputs)
AGENTCORE_GATEWAY_URL=
AGENTCORE_GATEWAY_TOKEN_ENDPOINT=
AGENTCORE_GATEWAY_OAUTH_SCOPES=agentcore/invoke
AGENTCORE_GATEWAY_CLIENT_ID=
AGENTCORE_GATEWAY_CLIENT_SECRET=

# Memory (optional — agent runs without it; get MEMORY_ID from stack outputs)
# MEMORY_ID=

# AppConfig (the degradation ladder). Unset = local default model, all features on.
# APPCONFIG_APPLICATION=
# APPCONFIG_ENVIRONMENT=
# APPCONFIG_PROFILE=

# L4 defer queue (the degradation ladder's floor — receipts queue here when every
# model rung is exhausted). Unset locally; set from stack outputs in a deployed stack.
# DEFER_QUEUE_URL=

# Fault injection for the 503-step-down test hook. The deployed sample sets this true
# so tests can exercise the in-agent step-down; leave UNSET (inert) for normal dev.
# A production deploy would NOT enable it.
# ALLOW_FAULT_INJECTION=true
