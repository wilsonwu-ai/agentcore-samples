# AWS Configuration (uses default credential chain if not set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Agent model via LiteLLM → Bedrock (no external API key needed)
BEDROCK_MODEL_ID=bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Optional: Use Gemini natively instead (requires Google API key)
# GOOGLE_API_KEY=your-key-here
# Then change model in agent.py to: "gemini-2.5-flash"
