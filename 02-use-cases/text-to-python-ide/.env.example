# AWS Configuration
# Option 1: Use AWS Profile (Recommended)
AWS_PROFILE=default
AWS_REGION=us-east-1

# Option 2: Use Access Keys (only if no profile is set up)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# AgentCore Runtime Configuration
AGENTCORE_RUNTIME_PORT=8080

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000

# AgentCore Memory — persistent cross-session memory and session persistence
# Run: python setup_memory.py to create
AGENTCORE_MEMORY_ID=

# AgentCore Runtime — set this to forward generate/execute to the deployed runtime
# Leave empty to use local agents instead
AGENTCORE_RUNTIME_ARN=
AGENTCORE_RUNTIME_ENDPOINT=DEFAULT

# Bedrock Guardrails — content safety filtering
# Run: python setup_guardrails.py to create
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=

# Timeout Configurations (in seconds)
AWS_READ_TIMEOUT=600
AWS_CONNECT_TIMEOUT=120
AWS_MAX_RETRIES=5

# Frontend execution timeout display
REACT_APP_EXECUTION_TIMEOUT_WARNING=300
REACT_APP_MAX_EXECUTION_TIME=600

# Notes:
# - AWS Profile authentication is preferred over access keys
# - If AWS_PROFILE is set, access keys will be ignored
# - Make sure your AWS profile has access to Amazon Bedrock
# - For AgentCore features, you need bedrock-agentcore permissions
# - Without AgentCore permissions, the app will use Strands simulation
# - Guardrails require a Bedrock Guardrail resource (python setup_guardrails.py)
# - Sessions require AgentCore Memory (python setup_memory.py)
